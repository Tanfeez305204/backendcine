PORT=5000
NODE_ENV=development
TRUST_PROXY=false

# Required:
# Use your project URL and service role key from Supabase project settings.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local Redis:
REDIS_URL=redis://127.0.0.1:6379

# Upstash REST alternative:
# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-rest-token

# Keep admin/auth origins here. Public GET routes stay accessible from any frontend origin.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://admin-nxe4.vercel.app

JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_SECONDS=604800
REFRESH_TOKEN_COOKIE_MAX_AGE=604800000
REFRESH_COOKIE_NAME=cinestream_refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=cinestream/thumbnails
MAX_FILE_SIZE_MB=5

DEFAULT_ADMIN_EMAIL=admin@cinestream.com
DEFAULT_ADMIN_PASSWORD=Admin@123
